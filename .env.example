# --- Production Configuration ---
NODE_ENV=production
TZ=Asia/Kathmandu
PORT=3000
HOST=0.0.0.0

# MongoDB connection URI (Cloud recommended for production)
MONGO_URI=mongodb+srv://<username>:<password>@cluster.mongodb.net/dating-app-db

# Firebase configuration
FIREBASE_SERVICE_ACCOUNT_PATH=./firebase-service-account.json
FIREBASE_STORAGE_BUCKET=your-app.firebasestorage.app

# Security & Encryption
# Use strong, long random strings for these in production!
MESSAGE_ENCRYPTION_KEY=your-super-secret-encryption-key
JWT_SECRET=your-super-secret-jwt-key
JWT_EXPIRES_IN=30d

# CORS (Restrict to your frontend domain in production)
CORS_ORIGIN=https://your-dating-app.com

# App Defaults & Logic
DEFAULT_AGE_MIN=18
DEFAULT_AGE_MAX=50
DEFAULT_DISTANCE_KM=10
DEFAULT_PAGINATION_LIMIT=20
DEFAULT_USER_NAME=Unknown

# Free User Limits
FREE_DAILY_SEND_LIMIT=20
FREE_DAILY_REVEAL_LIMIT=2
FREE_DAILY_REVIEW_LIMIT=2

# Payload & Infrastructure
JSON_PAYLOAD_LIMIT=10mb
LOG_MAX_SIZE=5242880
LOG_MAX_FILES=5

# Rate Limiting
GENERAL_LIMIT_WINDOW_MS=900000
GENERAL_LIMIT_MAX=100
AUTH_LIMIT_WINDOW_MS=3600000
AUTH_LIMIT_MAX=100
REPORT_LIMIT_WINDOW_MS=3600000
REPORT_LIMIT_MAX=5
